{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "concurrency": "15",
  "tasks": {
    "//#check:format": {},
    "//#check:packages": {},
    "//#format": {},
    "//#lint": {
      "cache": false
    },
    "//#lint:fix": {},
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "check": {
      "dependsOn": ["//#check:format", "//#lint", "test", "//#check:packages"]
    },
    "clean": {
      "dependsOn": ["^clean"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "fix": {
      "dependsOn": ["//#lint:fix", "//#format"]
    },
    "setup": {
      "dependsOn": ["^setup"],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"]
    }
  },
  "globalEnv": ["NODE_ENV"]
}
